# ============================================
# Dental Clinic Management System
# Variables de Entorno
# ============================================

# --- Aplicación ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# --- Base de Datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dental_clinic
DB_USER=postgres
DB_PASSWORD=S@ntos9403
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# --- JWT ---
JWT_SECRET=super-secret-jwt-key-change-in-production-2024
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-2024
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=12

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5

# --- Uploads ---
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# --- Logging ---
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# --- Clinic Defaults ---
CLINIC_NAME=Clínica Dental Sonrisa
CLINIC_TIMEZONE=America/Mexico_City
